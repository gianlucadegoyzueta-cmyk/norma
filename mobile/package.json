{
  "name": "norma-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Guscio nativo iOS/Android di Norma (Capacitor). Carica l'app web live e aggiunge funzioni native (push, scansione documento, biometria, deep link).",
  "scripts": {
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "cap:ios": "cap open ios",
    "cap:android": "cap open android",
    "cap:run:ios": "cap run ios",
    "cap:run:android": "cap run android",
    "assets:generate": "capacitor-assets generate --assetPath assets"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^7.0.0",
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@pantrist/capacitor-plugin-ml-kit-text-recognition": "^6.2.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.0"
  }
}
