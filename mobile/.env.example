# URL dell'app web che la webview nativa carica.
# Default (se non impostato): https://app.norma.casa
# In sviluppo si può puntare a un'anteprima o a un tunnel locale, es:
#   NORMA_APP_URL=https://norma-git-feat-xyz.vercel.app
#   NORMA_APP_URL=http://192.168.1.10:3000   (device sulla stessa rete del dev)
NORMA_APP_URL=https://app.norma.casa
