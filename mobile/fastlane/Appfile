# Identificativi app per Fastlane. I valori legati all'account si leggono da ENV (placeholder
# finché non hai gli account): mai hardcodare team id / apple id segreti nel repo.

app_identifier("casa.norma.app")

# iOS — Apple Developer / App Store Connect
apple_id(ENV["APPLE_ID"])              # email dell'account Apple Developer
itc_team_id(ENV["ASC_TEAM_ID"])        # App Store Connect team id (numerico)
team_id(ENV["APPLE_TEAM_ID"])          # Developer Portal Team ID (es. ABCDE12345)

# Android — package + service account JSON del Play Developer API (path, gitignored)
for_platform(:android) do
  package_name("casa.norma.app")
  json_key_file(ENV["SUPPLY_JSON_KEY"])
end
