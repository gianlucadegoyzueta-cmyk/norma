// ============================================================
//  SaaS Compliance Affitti Brevi — Modello dati
//
//  Convenzioni:
//   - Nomi in inglese; termini di dominio in italiano dove non
//     esiste un equivalente pulito (Schedina, Comune, Soggiorno…).
//   - "Organization" = il tenant/cliente (host singolo o property manager).
//   - Ogni tabella multi-tenant porta organizationId ESPLICITO:
//     isolamento dei dati per cliente, semplice e robusto.
//   - Il denaro è sempre in centesimi (Int), mai in virgola mobile.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL: transaction pooler (porta 6543) — usata dall'app a runtime (serverless-friendly).
  url       = env("DATABASE_URL")
  // DIRECT_URL: session pooler / connessione diretta (porta 5432) — usata da `prisma migrate`
  // (le migrazioni richiedono una sessione, non il transaction pooler).
  directUrl = env("DIRECT_URL")
}

// ----------------------------- ENUM -----------------------------

enum MembershipRole {
  OWNER // proprietario dell'organizzazione (privilegi massimi)
  ADMIN
  MEMBER
}

enum CredentialCategory {
  SINGOLA // utenza Alloggiati di UNA singola struttura
  GESTIONE_APPARTAMENTI // utenza che gestisce N appartamenti (stessa provincia)
}

enum CredentialStatus {
  ACTIVE // funzionante
  PENDING_REONBOARDING // da (ri)validare: es. dopo il cambio password dell'host
  INVALID // autenticazione fallita
  DISABLED // disattivata dall'utente
}

enum Sex {
  M // nel tracciato Alloggiati: 1
  F // nel tracciato Alloggiati: 2
}

enum TipoAlloggiato {
  OSPITE_SINGOLO // cod. 16 — documento OBBLIGATORIO
  CAPO_FAMIGLIA // cod. 17 — documento OBBLIGATORIO
  CAPO_GRUPPO // cod. 18 — documento OBBLIGATORIO
  FAMILIARE // cod. 19 — campi documento in BIANCO
  MEMBRO_GRUPPO // cod. 20 — campi documento in BIANCO
}

/// Origine di una prenotazione importata via iCal. Dedotta dall'URL del feed
/// (host Airbnb/Booking/VRBO); OTHER per qualsiasi altro calendario RFC5545.
enum ReservationSource {
  AIRBNB
  BOOKING
  VRBO
  OTHER
}

/// Stato di import di un Soggiorno nato da un feed iCal (null = soggiorno creato a mano).
///  - DRAFT: importato, da completare con gli ospiti.
///  - CANCELLED: l'evento è sparito dal feed mentre il soggiorno era ANCORA bozza → annullato in automatico.
///  - NEEDS_CANCEL_REVIEW: l'evento è sparito ma l'host aveva già inserito ospiti → si segnala, non si tocca.
enum StayImportStatus {
  DRAFT
  CANCELLED
  NEEDS_CANCEL_REVIEW
}

// Stati dell'outbox (decisione architetturale presa):
enum SchedinaStatus {
  PENDING // creata, non ancora inviata
  SENDING // invio in corso (persistito PRIMA della chiamata di rete)
  ACQUIRED // acquisita da Alloggiati (esito riga = true)
  REJECTED // scartata con errore → correggibile e re-inviabile
  UNVERIFIED // inviata ma esito ignoto (timeout) → riconciliare a T+1
  NEEDS_REVIEW // esauriti i tentativi automatici → richiede intervento umano (poi si rimette in coda)
}

enum SubmissionChannel {
  WEB_SERVICE // invio normale via web service SOAP
  PEC // fallback: PEC alla Questura quando il portale è giù
}

/// Stato di compliance del CIN (Codice Identificativo Nazionale) su un immobile.
/// Il CIN si ottiene sul portale BDSR del Ministero del Turismo (SPID/CIE) e si inserisce a mano.
enum CinStatus {
  PENDING // non ancora ottenuto/inserito (default: tutti gli immobili esistenti post-migrazione)
  OBTAINED // CIN validato e salvato
  NOT_REQUIRED // l'host ha dichiarato che per questo immobile non serve
}

/// Tipo di utente, raccolto nell'onboarding per personalizzare copy e passi del wizard.
enum OnboardingUserType {
  HOST_SINGOLO // gestisce una o poche strutture proprie
  PROPERTY_MANAGER // gestisce strutture di terzi / molte strutture
}

// -------------------------- TENANT & UTENTI --------------------------

/// Il tenant/cliente. Può essere un host con una sola struttura
/// oppure un property manager con molte credenziali e immobili.
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships            Membership[]
  credentials            AlloggiatiCredential[]
  properties             Property[]
  stays                  Stay[]
  guests                 Guest[]
  schedine               Schedina[]
  touristTaxDeclarations TouristTaxDeclaration[]
  onboardingProgress     OnboardingProgress?
  checkinTokens          CheckinToken[]
  istatSubmissions       IstatSubmission[]
  reservationImports     ReservationImport[]
}

/// Registro degli invii ISTAT (movimento turistico): traccia che un mese è stato dichiarato, con
/// i totali e lo snapshot delle righe al momento dell'invio. Audit-trail di compliance. Il report
/// resta calcolato on-demand; questo è la "ricevuta" dell'avvenuta dichiarazione (1 per mese).
model IstatSubmission {
  id             String   @id @default(cuid())
  organizationId String
  period         String // "YYYY-MM"
  arriviTotal    Int
  presenzeTotal  Int
  rows           Json // snapshot delle righe (provenienza/arrivi/presenze) al momento dell'invio
  submittedAt    DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, period])
}

/// Stato "soft" del wizard di onboarding di un'Organization: i passi NON derivabili dai dati di
/// dominio (benvenuto/identità, tipo utente, n° strutture, ultimo step visitato). I passi "duri"
/// (credenziale ATTIVA, tabelle, immobile) restano DERIVATI da getOnboardingState — qui non si
/// duplicano. 1:1 con Organization (organizationId UNIQUE).
model OnboardingProgress {
  id              String              @id @default(cuid())
  organizationId  String              @unique
  userType        OnboardingUserType?
  structuresCount Int? // stima dichiarata in fase di onboarding (solo per personalizzare il copy)
  welcomedAt      DateTime? // step 0 visto
  identityDoneAt  DateTime? // step 1 (attività) completato
  currentStep     Int                 @default(0) // ultimo step visitato → ripresa refresh-safe
  completedAt     DateTime? // wizard concluso (step finale)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// Persona che accede all'app. Campi compatibili con Auth.js.
/// Metodi di accesso supportati: email+password (`passwordHash`), magic link, Google.
/// `passwordHash` è null per gli utenti che NON usano la password (solo magic link / OAuth):
/// è il discriminante usato dal provider Credentials per rifiutare gentilmente quei login.
model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  emailVerified       DateTime?
  image               String?
  /// Hash bcrypt della password (mai in chiaro, mai loggato). Null = utente senza password.
  passwordHash        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  memberships         Membership[]
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
}

/// Token monouso per il reset password ("password dimenticata"). NON riusa VerificationToken
/// (gestito da Auth.js per i magic link): qui controlliamo noi ciclo di vita e revoca.
/// `tokenHash` = SHA-256 del token spedito via email: a DB non c'è mai il token in chiaro.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expires   DateTime
  usedAt    DateTime? // valorizzato al primo uso → monouso
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Ponte User <-> Organization: un utente può appartenere a PIÙ organizzazioni
/// (es. un collaboratore/agenzia che gestisce più clienti) e un'organizzazione
/// può avere PIÙ utenti del team.
model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId]) // un utente una sola volta per organizzazione
  @@index([userId])
}

// ----------------------- CREDENZIALI ALLOGGIATI -----------------------

/// "1 Organization -> N credenziali eterogenee".
/// IMPORTANTISSIMO: utente/password/wskey NON stanno qui in chiaro.
/// Qui c'è solo `secretRef`, un riferimento opaco al secrets manager.
/// Il recupero/decifratura avviene dietro l'interfaccia SecretsVault.
model AlloggiatiCredential {
  id             String             @id @default(cuid())
  organizationId String
  label          String // etichetta leggibile, es. "Struttura Trastevere – RM"
  category       CredentialCategory
  provincia      String // sigla, es. "RM". Una GESTIONE_APPARTAMENTI copre UNA sola provincia.
  status         CredentialStatus   @default(PENDING_REONBOARDING)

  secretRef String @unique // riferimento al vault (NON il segreto in chiaro)

  // Metadati operativi (NON il token vero: quello è effimero e vive in cache a runtime)
  lastVerifiedAt DateTime? // ultimo Authentication_Test andato a buon fine
  tokenExpiresAt DateTime? // scadenza nota del token corrente (per il refresh "lazy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  properties   Property[] // per GESTIONE_APPARTAMENTI: gli immobili gestiti
  schedine     Schedina[]

  @@index([organizationId])
  @@index([status])
}

// ------------------------ IMMOBILI / APPARTAMENTI ------------------------

/// Unifichiamo "Immobile" (nostro concetto) e "Appartamento" (concetto Alloggiati).
/// `alloggiatiApartmentId` è valorizzato SOLO quando l'immobile è registrato sotto
/// una credenziale GESTIONE_APPARTAMENTI; per le SINGOLA resta null.
model Property {
  id             String @id @default(cuid())
  organizationId String
  name           String // nome interno, es. "Bilocale Trastevere"
  address        String
  comuneId       String
  proprietario   String // sotto una stessa credenziale possono esserci proprietari diversi

  credentialId          String? // credenziale con cui si inviano le schedine (nullable)
  alloggiatiApartmentId String? // IdAppartamento assegnato da Alloggiati (solo gestione appartamenti)

  /// Codice Identificativo Nazionale (normalizzato: maiuscolo, senza spazi). Null finché non ottenuto.
  cin       String?
  cinStatus CinStatus @default(PENDING)

  // Tassa di soggiorno: categoria struttura (es. "AFFITTO_BREVE", "CAV") e zona del comune
  // (Venezia tariffa per zona). Alimentano la risoluzione della tariffa nel calcolatore.
  accommodationCategory String? // null = si userà la tariffa jolly DEFAULT del comune
  touristTaxZone        String? // null = zona DEFAULT del comune

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  comune             Comune                @relation(fields: [comuneId], references: [id])
  credential         AlloggiatiCredential? @relation(fields: [credentialId], references: [id])
  stays              Stay[]
  reservationImports ReservationImport[]

  @@index([organizationId])
  @@index([credentialId])
}

// --------------------------- SOGGIORNI & OSPITI ---------------------------

model Stay {
  id             String    @id @default(cuid())
  organizationId String
  propertyId     String
  arrivalDate    DateTime // fa scattare la deadline (24h, o 6h se soggiorno breve)
  departureDate  DateTime?
  guestsCount    Int
  isShortStay    Boolean   @default(false) // soggiorno <=24h → deadline a +6h

  // --- Import iCal (additivo, tutto nullable: i soggiorni creati a mano restano invariati) ---
  /// UID dell'evento iCal: chiave di dedup per il re-sync (upsert per import).
  icalUid             String?
  importSource        ReservationSource?
  importStatus        StayImportStatus? // null = soggiorno NON importato (creato a mano)
  reservationImportId String? // feed di provenienza

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property          Property           @relation(fields: [propertyId], references: [id])
  guests            Guest[]
  checkinTokens     CheckinToken[]
  reservationImport ReservationImport? @relation(fields: [reservationImportId], references: [id], onDelete: SetNull)

  @@unique([reservationImportId, icalUid]) // dedup UID per feed (NULL multipli ammessi → soggiorni a mano ok)
  @@index([organizationId])
  @@index([propertyId])
  @@index([reservationImportId])
}

/// Sorgente di prenotazioni per un immobile: un URL iCal (Airbnb/Booking/VRBO) che l'host
/// incolla. Norma lo legge e crea/aggiorna i Soggiorni in bozza. Un immobile può avere più
/// feed (es. Airbnb + Booking). NIENTE segreti qui: l'URL iCal è un link "a sola lettura"
/// pubblico ma non indicizzato — lo trattiamo come dato normale (non passa dal SecretsVault).
model ReservationImport {
  id             String            @id @default(cuid())
  organizationId String
  propertyId     String
  url            String
  source         ReservationSource @default(OTHER)

  lastSyncAt   DateTime? // ultimo sync tentato
  lastError    String? // messaggio dell'ultimo sync fallito (null = ultimo sync ok)
  lastImported Int       @default(0) // n° prenotazioni viste nell'ultimo sync riuscito

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  stays        Stay[]

  @@unique([propertyId, url]) // stesso feed una sola volta per immobile
  @@index([organizationId])
  @@index([propertyId])
}

/// Token del link PUBBLICO di check-in self-service per un soggiorno. Stessa filosofia di
/// PasswordResetToken: a DB solo lo SHA-256 (`tokenHash`), il valore in chiaro vive solo nell'URL
/// dato all'ospite. A scadenza; `completedAt` lo "chiude" dopo l'invio dei dati.
model CheckinToken {
  id             String    @id @default(cuid())
  organizationId String
  stayId         String
  tokenHash      String    @unique
  expiresAt      DateTime
  completedAt    DateTime? // valorizzato quando l'ospite completa il check-in
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stay         Stay         @relation(fields: [stayId], references: [id], onDelete: Cascade)

  @@index([stayId])
}

/// Un Ospite è legato a UN soggiorno (niente anagrafica persistente: scelta GDPR-friendly).
/// `tipoAlloggiato` determina le regole del tracciato (documento obbligatorio per 16/17/18,
/// in bianco per 19/20). `leaderId` (auto-relazione) collega familiari/membri al capo.
/// NB: i campi documento sono OPZIONALI a DB proprio perché per FAMILIARE/MEMBRO_GRUPPO
///     non vanno compilati; l'obbligatorietà per gli altri la impone la logica di dominio.
model Guest {
  id             String @id @default(cuid())
  organizationId String
  stayId         String

  firstName String
  lastName  String
  sex       Sex
  birthDate DateTime

  birthCountryId String // Stato di nascita — SEMPRE obbligatorio
  birthComuneId  String? // Comune di nascita — solo se Stato = Italia
  citizenshipId  String // cittadinanza — sempre obbligatoria

  // Residenza (PROVENIENZA) — usata da ISTAT (arrivi/presenze per provenienza) e dal check-in.
  // Additiva e OPZIONALE: non serve ad Alloggiati (basato sulla nascita); raccolta dove disponibile,
  // con fallback approssimato lato ISTAT finché non è valorizzata. residenceComuneId solo se Italia.
  residenceCountryId String? // Stato di residenza
  residenceComuneId  String? // Comune di residenza (solo se residenza in Italia)

  documentTypeId  String? // documento: obbligatorio solo per 16/17/18
  documentNumber  String?
  documentPlaceId String? // luogo di rilascio (Stato o Comune)

  tipoAlloggiato TipoAlloggiato
  leaderId       String? // punta al capo famiglia/gruppo (per familiari/membri)

  // Tassa di soggiorno: tipo di esenzione dichiarato per l'ospite (deve combaciare con
  // rule.exemptions.types del comune, es. "FORZE_ORDINE", "DAY_HOSPITAL_PATIENT").
  // null = nessuna esenzione per categoria (resta possibile la riduzione per età).
  taxExemptionType String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stay             Stay          @relation(fields: [stayId], references: [id], onDelete: Cascade)
  leader           Guest?        @relation("GuestGroup", fields: [leaderId], references: [id])
  members          Guest[]       @relation("GuestGroup")
  birthCountry     Country       @relation("GuestBirthCountry", fields: [birthCountryId], references: [id])
  birthComune      Comune?       @relation("GuestBirthComune", fields: [birthComuneId], references: [id])
  citizenship      Country       @relation("GuestCitizenship", fields: [citizenshipId], references: [id])
  documentType     DocumentType? @relation(fields: [documentTypeId], references: [id])
  residenceCountry Country?      @relation("GuestResidenceCountry", fields: [residenceCountryId], references: [id])
  residenceComune  Comune?       @relation("GuestResidenceComune", fields: [residenceComuneId], references: [id])
  schedina         Schedina?

  @@index([organizationId])
  @@index([stayId])
}

// ----------------------------- OUTBOX SCHEDINE -----------------------------

/// Tabella outbox: una riga per OGNI schedina (= un ospite di un soggiorno).
/// L'invio è IRREVERSIBILE e il `Send` di Alloggiati NON è idempotente, perciò:
///  - `dedupKey` UNIQUE impedisce di creare due intenti identici (doppioni non eliminabili);
///  - lo stato segue PENDING → SENDING → ACQUIRED / REJECTED / UNVERIFIED;
///  - i campi di ricevuta/riconciliazione servono al controllo differito (T+1, via metodo Ricevuta).
model Schedina {
  id             String @id @default(cuid())
  organizationId String
  guestId        String @unique // 1 ospite : 1 schedina
  credentialId   String

  status  SchedinaStatus    @default(PENDING)
  channel SubmissionChannel @default(WEB_SERVICE)

  /// hash(struttura|idAppartamento|dataArrivo|numeroDocumento|cognome|nome|dataNascita).
  /// Non include i giorni di permanenza: un prolungamento si gestisce come ri-emissione
  /// della STESSA riga (transizione di stato), non come nuova riga.
  dedupKey String

  payloadSnapshot String? // stringa del tracciato effettivamente inviata (audit/riconciliazione)
  deadlineAt      DateTime // arrivo +24h (o +6h se soggiorno <=24h)

  attempts     Int     @default(0)
  lastErrorCod String?
  lastErrorDes String?

  sentAt       DateTime?
  acquiredAt   DateTime?
  receiptDate  DateTime? // data della Ricevuta su cui risulta (T+1)
  receiptRef   String? // riferimento all'archiviazione della ricevuta PDF
  reconciledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  guest        Guest                @relation(fields: [guestId], references: [id], onDelete: Cascade)
  credential   AlloggiatiCredential @relation(fields: [credentialId], references: [id])
  events       SchedinaEvent[]

  @@unique([organizationId, dedupKey]) // ← barriera anti-doppione
  @@index([status])
  @@index([deadlineAt])
}

/// Log append-only delle transizioni di stato: audit + debug dell'outbox.
model SchedinaEvent {
  id         String          @id @default(cuid())
  schedinaId String
  fromStatus SchedinaStatus?
  toStatus   SchedinaStatus
  message    String?
  createdAt  DateTime        @default(now())

  schedina Schedina @relation(fields: [schedinaId], references: [id], onDelete: Cascade)

  @@index([schedinaId])
}

// --------- TABELLE DI RIFERIMENTO (codifiche ufficiali Alloggiati) ---------
// Si sincronizzeranno dal metodo `Tabella` del web service. Qui solo lo scheletro.

model Comune {
  id        String @id @default(cuid())
  code      String @unique // codice catastale/Alloggiati
  name      String
  provincia String // sigla

  properties             Property[]
  guestsBirth            Guest[]                 @relation("GuestBirthComune")
  guestsResidence        Guest[]                 @relation("GuestResidenceComune")
  touristTaxConfigs      TouristTaxConfig[] // 1:N — versioni tariffarie nel tempo
  touristTaxDeclarations TouristTaxDeclaration[]
}

model Country {
  id   String @id @default(cuid())
  code String @unique // codice Stato (tabella Stati)
  name String

  guestsBirth       Guest[] @relation("GuestBirthCountry")
  guestsCitizenship Guest[] @relation("GuestCitizenship")
  guestsResidence   Guest[] @relation("GuestResidenceCountry")
}

model DocumentType {
  id     String  @id @default(cuid())
  code   String  @unique // codice tipo documento (tabella Documenti)
  name   String
  guests Guest[]
}

// --------- CAVEAU SEGRETI (cifrati) ---------

/// Una riga = un AlloggiatiSecret (utente/password/wskey) cifrato con AES-256-GCM.
/// `AlloggiatiCredential.secretRef` punta all'id di questa riga. È il backend DUREVOLE del
/// SecretsVault: a differenza del vault su file locale, sopravvive su runtime serverless (Vercel).
/// La chiave di cifratura sta SOLO in env (SECRETS_LOCAL_KEY), mai nel DB.
model Secret {
  id        String   @id @default(cuid())
  iv        String // nonce GCM (hex)
  authTag   String // tag di autenticazione GCM (hex)
  data      String // ciphertext (hex)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --------- TASSA DI SOGGIORNO (predisposta, NON implementata) ---------

/// Configurazione tariffaria per Comune. Regole in JSON per ora (ogni Comune ha regole
/// diverse: importi per notte/categoria, esenzioni, numero massimo di notti…).
/// Struttureremo meglio quando implementeremo il calcolo.
model TouristTaxConfig {
  id        String    @id @default(cuid())
  comuneId  String
  rules     Json
  validFrom DateTime
  validTo   DateTime?

  comune Comune @relation(fields: [comuneId], references: [id])

  // Una sola versione per (comune, data inizio validità). Sostituisce il vecchio
  // `comuneId @unique`, che impediva il versionamento per data delle tariffe.
  @@unique([comuneId, validFrom])
  @@index([comuneId])
}

/// Stato della dichiarazione periodica. Macchina a stati validata nel dominio:
/// DRAFT → READY → SUBMITTED → PAID. (Annullabile a CANCELLED da DRAFT/READY.)
enum TaxDeclarationStatus {
  DRAFT // in costruzione/ricalcolabile
  READY // congelata, pronta all'export/invio
  SUBMITTED // inviata al comune (export scaricato o canale assistito)
  PAID // versamento confermato
  CANCELLED // annullata prima dell'invio
}

/// Modalità di versamento scelta per una dichiarazione. MANUAL_EXPORT è il default sicuro
/// (l'utente scarica ed invia da sé). Gli altri sono canali assistiti, attivabili per comune.
enum TaxRemittanceMode {
  MANUAL_EXPORT
  GECOS
  PAGOPA
  COMUNE_PORTAL
}

/// Dichiarazione/versamento periodico della tassa, per organizzazione + comune + periodo.
/// `amountCents` è il totale dovuto (somma delle righe). Le righe (TouristTaxDeclarationLine)
/// tengono il dettaglio per soggiorno, per la trasparenza e l'export verso il comune.
model TouristTaxDeclaration {
  id             String               @id @default(cuid())
  organizationId String
  comuneId       String
  period         String // es. "2026-05" (mese) o "2026-Q2" (trimestre)
  amountCents    Int                  @default(0) // denaro in centesimi
  status         TaxDeclarationStatus @default(DRAFT)
  remittanceMode TaxRemittanceMode    @default(MANUAL_EXPORT)
  submittedAt    DateTime?
  paidAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  comune       Comune                      @relation(fields: [comuneId], references: [id])
  lines        TouristTaxDeclarationLine[]

  @@unique([organizationId, comuneId, period])
  @@index([organizationId])
  @@index([status])
}

/// Riga di dettaglio di una dichiarazione: l'imposta dovuta per UN soggiorno nel periodo.
/// `breakdown` conserva il dettaglio per-ospite (esente/ridotto/motivo) prodotto dal
/// calcolatore, per audit e trasparenza verso il comune.
model TouristTaxDeclarationLine {
  id            String @id @default(cuid())
  declarationId String
  stayId        String
  propertyName  String // denormalizzato: l'export resta leggibile anche se la struttura cambia
  taxedNights   Int    @default(0)
  amountCents   Int    @default(0)
  breakdown     Json // GuestTaxBreakdown[] serializzato (dettaglio per-ospite)

  declaration TouristTaxDeclaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  @@unique([declarationId, stayId]) // un soggiorno una sola volta per dichiarazione
  @@index([declarationId])
}

// ----------------------- AUTENTICAZIONE (Auth.js / NextAuth) -----------------------
// Modelli richiesti dall'adapter Prisma di Auth.js.
// `Account` = account di provider esterni (OAuth): con il solo magic-link resta vuoto,
// ma fa parte dello schema standard dell'adapter. (Da non confondere con Organization, il tenant.)

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
