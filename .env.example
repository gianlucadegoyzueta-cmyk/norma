# Copia questo file in ".env" e compila i valori.

# Database PostgreSQL.
# - Sviluppo locale: docker-compose incluso (docker compose up -d db) → entrambe uguali.
# - Supabase: DATABASE_URL = transaction pooler (porta 6543) per l'app a runtime;
#             DIRECT_URL  = session pooler (porta 5432) per le migrazioni Prisma.
DATABASE_URL="postgresql://compliance:compliance@localhost:5432/compliance?schema=public"
DIRECT_URL="postgresql://compliance:compliance@localhost:5432/compliance?schema=public"

# Chiave per la cifratura LOCALE dei segreti (solo sviluppo): 32 byte in esadecimale.
# Generane una con:  openssl rand -hex 32
SECRETS_LOCAL_KEY="genera-con-openssl-rand-hex-32"

NODE_ENV="development"

# --- Autenticazione (Auth.js / NextAuth v5) ---
# Segreto per firmare le sessioni. Genera con:  openssl rand -base64 32
AUTH_SECRET="genera-con-openssl-rand-base64-32"
# Mittente dei magic link.
EMAIL_FROM="no-reply@compliance.local"
# SMTP per l'invio reale (produzione). In sviluppo lascia vuoto: il link è stampato in console.
EMAIL_SERVER=""
