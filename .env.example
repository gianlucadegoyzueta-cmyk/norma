# Copia questo file in ".env" e compila i valori.

# Database PostgreSQL.
# - Sviluppo locale: docker-compose incluso (docker compose up -d db) → entrambe uguali.
# - Supabase: DATABASE_URL = transaction pooler (porta 6543) per l'app a runtime;
#             DIRECT_URL  = session pooler (porta 5432) per le migrazioni Prisma.
DATABASE_URL="postgresql://compliance:compliance@localhost:5432/compliance?schema=public"
DIRECT_URL="postgresql://compliance:compliance@localhost:5432/compliance?schema=public"

# Chiave per la cifratura LOCALE dei segreti (solo sviluppo): 32 byte in esadecimale.
# Generane una con:  openssl rand -hex 32
SECRETS_LOCAL_KEY="genera-con-openssl-rand-hex-32"

NODE_ENV="development"

# --- Autenticazione (Auth.js / NextAuth v5) ---
# Segreto per firmare le sessioni. Genera con:  openssl rand -base64 32
AUTH_SECRET="genera-con-openssl-rand-base64-32"
# URL canonico dell'app: NextAuth lo usa per costruire i magic link. In produzione = dominio reale
# (https://norma.casa); in locale lascia vuoto (NextAuth usa http://localhost:3000).
AUTH_URL=""
# Mittente dei magic link (in produzione un indirizzo sul dominio verificato su Resend).
EMAIL_FROM="no-reply@norma.casa"
# Chiave API Resend per l'invio reale (produzione). In sviluppo lascia vuoto: il link è stampato
# in console (vedi sendVerificationRequest in src/auth.ts). Non serve SMTP.
RESEND_API_KEY=""

# --- Google OAuth (opzionale) ---
# Se valorizzate, in /login e /signup compare "Continua con Google"; se vuote, il bottone resta
# nascosto (in sviluppo va benissimo senza). Crea le credenziali su Google Cloud Console →
# "OAuth 2.0 Client ID", con redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Sentry — osservabilità errori. DSN pubblico (non segreto). Org EU norma-i2 / progetto norma-app.
# Attivo solo in produzione (vedi sentry.*.config.ts). Per i sourcemap leggibili aggiungere
# SENTRY_AUTH_TOKEN nelle env di build (Vercel) — opzionale.
SENTRY_DSN="https://<public-key>@o<org>.ingest.de.sentry.io/<project>"
NEXT_PUBLIC_SENTRY_DSN="https://<public-key>@o<org>.ingest.de.sentry.io/<project>"

# Supporto AI — email del founder per le notifiche di escalation (fallback: EMAIL_FROM)
SUPPORT_NOTIFY_EMAIL=

# Supporto AI — allowlist email che vedono l'inbox /admin/support (comma-separated, vuota = nessuno)
SUPPORT_ADMIN_EMAILS=
