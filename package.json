{
  "name": "compliance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:password": "node scripts/set-db-password.mjs",
    "alloggiati:live-check": "RUN_LIVE_CHECK=1 vitest run src/server/modules/alloggiati/__tests__/soap.live-check.test.ts",
    "alloggiati:inspect-tables": "RUN_TABLE_INSPECT=1 vitest run src/server/modules/alloggiati/__tests__/soap.tabella-inspect.live.test.ts",
    "alloggiati:sync-tables": "RUN_TABLE_SYNC=1 vitest run src/server/modules/alloggiati/__tests__/soap.table-sync.live.test.ts",
    "alloggiati:test-real": "RUN_TEST_REAL=1 vitest run src/server/modules/alloggiati/__tests__/soap.test-real.live.test.ts",
    "alloggiati:gate0-pdf": "RUN_GATE0_PDF=1 vitest run src/server/modules/alloggiati/__tests__/soap.ricevuta-pdf.live.test.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.2.0",
    "@sentry/nextjs": "^10.57.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^4.5.0",
    "lucide-react": "^1.17.0",
    "next": "^15.5.19",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.21",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^6.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.6"
  }
}
