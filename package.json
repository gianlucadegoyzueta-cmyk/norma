{
  "name": "compliance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:password": "node scripts/set-db-password.mjs",
    "alloggiati:live-check": "RUN_LIVE_CHECK=1 vitest run src/server/modules/alloggiati/__tests__/soap.live-check.test.ts",
    "alloggiati:inspect-tables": "RUN_TABLE_INSPECT=1 vitest run src/server/modules/alloggiati/__tests__/soap.tabella-inspect.live.test.ts",
    "alloggiati:sync-tables": "RUN_TABLE_SYNC=1 vitest run src/server/modules/alloggiati/__tests__/soap.table-sync.live.test.ts",
    "alloggiati:test-real": "RUN_TEST_REAL=1 vitest run src/server/modules/alloggiati/__tests__/soap.test-real.live.test.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.2.0",
    "fast-xml-parser": "^4.5.0",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.2.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
